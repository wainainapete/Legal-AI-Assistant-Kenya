# ── LLM ──────────────────────────────────────────
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Vector DB ─────────────────────────────────────
# Free M0 cluster at: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/
MONGODB_DB_NAME=legal_ai_africa
MONGODB_COLLECTION_BENIN=legal_docs_benin
MONGODB_COLLECTION_MADAGASCAR=legal_docs_madagascar

# ── Auth (Supabase) ───────────────────────────────
# Free at: https://supabase.com
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── App Config ────────────────────────────────────
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
SECRET_KEY=your_random_secret_key_min_32_chars

# ── Safety ────────────────────────────────────────
# Confidence threshold below which answers go to human review
CONFIDENCE_THRESHOLD=0.75
MAX_TOKENS_RESPONSE=1024

# ── WhatsApp (Meta Cloud API - optional) ──────────
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
